<Window x:Class="NetworkUsage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Usage Monitor" 
        Height="400" 
        Width="600"
        MinHeight="300"
        MinWidth="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/NetworkUsage;component/icon.ico">
    
    <Window.Resources>
        <!-- Define styles for Windows 11 modern look -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E5E5E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="20"/>
        </Style>
        
        <Style x:Key="SpeedDisplayStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Network Usage Monitor" 
                   Style="{StaticResource HeaderTextStyle}"/>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Name="MainTabControl" Margin="10">
            
            <!-- Current Status Tab -->
            <TabItem Header="Current Status">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Active Adapter Info -->
                    <Border Grid.Row="0" 
                            Background="#F8F8F8" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            Padding="15" 
                            Margin="0,0,0,20"
                            CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="Active Network Adapter" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                            <TextBlock Name="ActiveAdapterText" Text="No adapter selected" FontSize="14"/>
                            <TextBlock Name="AdapterStatusText" Text="Status: Unknown" FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Speed Display -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Download Speed -->
                        <Border Grid.Column="0" 
                                Background="#E3F2FD" 
                                BorderBrush="#2196F3" 
                                BorderThickness="2" 
                                Padding="20" 
                                Margin="0,0,10,0"
                                CornerRadius="8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📥 Download" 
                                          FontSize="16" 
                                          FontWeight="Bold" 
                                          HorizontalAlignment="Center" 
                                          Margin="0,0,0,10"/>
                                <TextBlock Name="DownloadSpeedText" 
                                          Text="0 B/s" 
                                          Style="{StaticResource SpeedDisplayStyle}"
                                          Foreground="#1976D2"/>
                                <TextBlock Name="DownloadTotalText" 
                                          Text="Total: 0 B" 
                                          FontSize="12" 
                                          HorizontalAlignment="Center" 
                                          Foreground="Gray"/>
                            </StackPanel>
                        </Border>

                        <!-- Upload Speed -->
                        <Border Grid.Column="1" 
                                Background="#E8F5E8" 
                                BorderBrush="#4CAF50" 
                                BorderThickness="2" 
                                Padding="20" 
                                Margin="10,0,0,0"
                                CornerRadius="8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="📤 Upload" 
                                          FontSize="16" 
                                          FontWeight="Bold" 
                                          HorizontalAlignment="Center" 
                                          Margin="0,0,0,10"/>
                                <TextBlock Name="UploadSpeedText" 
                                          Text="0 B/s" 
                                          Style="{StaticResource SpeedDisplayStyle}"
                                          Foreground="#388E3C"/>
                                <TextBlock Name="UploadTotalText" 
                                          Text="Total: 0 B" 
                                          FontSize="12" 
                                          HorizontalAlignment="Center" 
                                          Foreground="Gray"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Last Update Info -->
                    <TextBlock Grid.Row="2" 
                              Name="LastUpdateText" 
                              Text="Last update: Never" 
                              FontSize="12" 
                              HorizontalAlignment="Center" 
                              Foreground="Gray" 
                              Margin="0,20,0,0"/>
                </Grid>
            </TabItem>

            <!-- Network Adapters Tab -->
            <TabItem Header="Network Adapters">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                              Text="Available Network Adapters" 
                              FontWeight="Bold" 
                              FontSize="16" 
                              Margin="0,0,0,15"/>

                    <ListView Grid.Row="1" Name="AdapterListView" Margin="0,0,0,15">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Type" Width="120" DisplayMemberBinding="{Binding Type}"/>
                                <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="Speed" Width="100" DisplayMemberBinding="{Binding Speed}"/>
                                <GridViewColumn Header="Active" Width="60" DisplayMemberBinding="{Binding IsActive}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Name="RefreshAdaptersButton" 
                               Content="Refresh" 
                               Style="{StaticResource ModernButtonStyle}"/>
                        <Button Name="SetActiveAdapterButton" 
                               Content="Set Active" 
                               Style="{StaticResource ModernButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings">
                <ScrollViewer Margin="20">
                    <StackPanel>
                        <!-- Monitoring Settings -->
                        <GroupBox Header="Monitoring Settings" Margin="0,0,0,20" Padding="15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Update Interval:" Width="150" VerticalAlignment="Center"/>
                                    <ComboBox Name="UpdateIntervalComboBox" Width="120">
                                        <ComboBoxItem Content="500ms" Tag="500"/>
                                        <ComboBoxItem Content="1 second" Tag="1000" IsSelected="True"/>
                                        <ComboBoxItem Content="2 seconds" Tag="2000"/>
                                        <ComboBoxItem Content="5 seconds" Tag="5000"/>
                                    </ComboBox>
                                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <CheckBox Name="AutoScaleUnitsCheckBox" 
                                         Content="Auto-scale units (B/s → KB/s → MB/s → GB/s)" 
                                         IsChecked="True" 
                                         Margin="0,0,0,10"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Display Settings -->
                        <GroupBox Header="Display Settings" Margin="0,0,0,20" Padding="15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Theme:" Width="150" VerticalAlignment="Center"/>
                                    <ComboBox Name="ThemeComboBox" Width="150">
                                        <ComboBoxItem Content="Auto (Follow System)" Tag="Auto" IsSelected="True"/>
                                        <ComboBoxItem Content="Light" Tag="Light"/>
                                        <ComboBoxItem Content="Dark" Tag="Dark"/>
                                        <ComboBoxItem Content="High Contrast" Tag="HighContrast"/>
                                    </ComboBox>
                                </StackPanel>
                                
                                <CheckBox Name="ShowInSystemTrayCheckBox" 
                                         Content="Show icon in system tray" 
                                         IsChecked="True" 
                                         Margin="0,0,0,10"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Tooltip Format:" Width="150" VerticalAlignment="Center"/>
                                    <TextBox Name="TooltipFormatTextBox" 
                                            Width="200" 
                                            Text="↓{0} ↑{1}" 
                                            VerticalAlignment="Center"/>
                                    <Button Name="ApplyFormatButton" 
                                           Content="Apply" 
                                           Style="{StaticResource ModernButtonStyle}"
                                           Width="60"
                                           Height="30"
                                           Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Performance Settings -->
                        <GroupBox Header="Performance Settings" Padding="15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Response Timeout:" Width="150" VerticalAlignment="Center"/>
                                    <TextBox Name="ResponseTimeoutTextBox" 
                                            Width="80" 
                                            Text="100"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>
                                
                                <TextBlock Text="Current average response time: " FontSize="12" Foreground="Gray"/>
                                <TextBlock Name="AverageResponseTimeText" 
                                          Text="0.0ms" 
                                          FontSize="12" 
                                          Foreground="Gray" 
                                          Margin="0,0,0,10"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock Name="StatusBarText" Text="Ready"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Name="MonitoringStatusText" Text="Monitoring: Stopped" Margin="0,0,10,0"/>
                    <TextBlock Name="AdapterCountText" Text="Adapters: 0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>