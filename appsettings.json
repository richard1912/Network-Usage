{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "NetworkUsage": "Debug"
    },
    "Console": {
      "IncludeScopes": false,
      "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff "
    }
  },
  "Display": {
    "UpdateInterval": "00:00:01",
    "AutoScaleUnits": true,
    "CurrentTheme": "Auto",
    "ShowInSystemTray": true,
    "ToolTipFormat": "↓{0} ↑{1}",
    "ResponseTimeoutMs": 100
  },
  "NetworkMonitoring": {
    "AutoSelectPrimaryAdapter": true,
    "FilterVirtualAdapters": true,
    "FilterLoopbackAdapters": true,
    "AdapterPriorityOrder": ["Ethernet", "Wireless", "Other"],
    "MonitoringIntervalMs": 1000,
    "PerformanceTrackingEnabled": true
  },
  "TaskbarIntegration": {
    "AutoHideOnMinimize": true,
    "ShowContextMenu": true,
    "IconTheme": "Auto",
    "TooltipMaxLength": 127,
    "UpdateAnimationEnabled": false
  },
  "UIComponents": {
    "DefaultWindowWidth": 600,
    "DefaultWindowHeight": 450,
    "MinWindowWidth": 400,
    "MinWindowHeight": 300,
    "EnableAnimations": true,
    "SaveWindowPosition": true,
    "ThemeFollowsSystem": true
  },
  "Performance": {
    "MaxCpuUsagePercent": 1.0,
    "MaxMemoryUsageMB": 50,
    "MaxResponseTimeMs": 100,
    "EnablePerformanceMonitoring": true,
    "PerformanceReportingIntervalMs": 30000
  },
  "Application": {
    "Version": "1.0.0",
    "StartMinimized": false,
    "ShowSplashScreen": false,
    "AutoStartWithWindows": false,
    "CheckForUpdates": false
  }
}